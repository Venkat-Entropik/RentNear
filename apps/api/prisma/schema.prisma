// ──────────────────────────────────────────────────────────────────────────────
// apps/api/prisma/schema.prisma
// RentNear - Schema v2: Auth + Users & KYC
// ──────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  RENTER
  ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DocType {
  AADHAAR
  PAN
  PASSPORT
  DRIVING_LICENSE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

// ── User ──────────────────────────────────────────────────────────────────────
// Core user record - created on first successful OTP verification.

model User {
  id        String    @id @default(cuid())
  phone     String    @unique
  email     String?   @unique
  name      String?
  avatarUrl String?
  role      Role      @default(RENTER)
  kycStatus KycStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  otpSessions   OtpSession[]
  refreshTokens RefreshToken[]
  addresses     Address[]
  kycDocument   KycDocument?
  listings      Listing[]
  bookings      Booking[]      @relation("BookingRenter")
  payments      Payment[]
  reviews       Review[]

  conversationsAsRenter Conversation[] @relation("RenterConversations")
  conversationsAsOwner  Conversation[] @relation("OwnerConversations")
  messages              Message[]
  disputes              Dispute[]

  @@map("users")
}

// ── OtpSession ────────────────────────────────────────────────────────────────
// OTPs are stored HASHED (bcrypt) — raw OTP never persisted.

model OtpSession {
  id        String   @id @default(cuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([userId])
  @@map("otp_sessions")
}

// ── RefreshToken ──────────────────────────────────────────────────────────────
// SHA-256 hashed — raw token sent to client only once.

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Address ───────────────────────────────────────────────────────────────────
// User address book — used for listing proximity calculations.

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   // "Home", "Work", "Other"
  street    String
  city      String
  state     String
  pincode   String
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

// ── KycDocument ───────────────────────────────────────────────────────────────
// One KYC record per user — admin reviews and flips kycStatus on User.

model KycDocument {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  docType     DocType
  docNumber   String
  frontUrl    String
  backUrl     String?
  selfieUrl   String?
  status      KycStatus @default(PENDING)
  reviewNote  String?
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  @@map("kyc_documents")
}

// ── ListingCategory ───────────────────────────────────────────────────────────
// Seeded at startup — admin-managed category taxonomy.

model ListingCategory {
  id       String    @id @default(cuid())
  name     String    @unique
  icon     String?   // emoji or icon name
  listings Listing[]

  @@map("listing_categories")
}

// ── Listing ───────────────────────────────────────────────────────────────────
// Core marketplace item. Draft until isPublished = true.

model Listing {
  id          String          @id @default(cuid())
  ownerId     String
  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categoryId  String
  category    ListingCategory @relation(fields: [categoryId], references: [id])
  title       String
  description String
  pricePerDay Decimal         @db.Decimal(10, 2)
  deposit     Decimal?        @db.Decimal(10, 2)
  isPublished Boolean         @default(false)
  city        String
  state       String
  pincode     String
  lat         Float?
  lng         Float?
  rating      Float           @default(0)
  reviewCount Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  media        ListingMedia[]
  availability Availability[]
  bookings     Booking[]
  reviews      Review[]
  conversations Conversation[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([city])
  @@map("listings")
}

// ── ListingMedia ──────────────────────────────────────────────────────────────
// Photos uploaded to Cloudflare R2 via presigned URLs.

model ListingMedia {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String   // R2 public URL
  r2Key     String   // R2 object key (for deletion)
  order     Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([listingId])
  @@map("listing_media")
}

// ── Availability ──────────────────────────────────────────────────────────────
// Per-date availability grid. false = available, true = blocked/booked.

model Availability {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  isBlocked Boolean  @default(false)

  @@unique([listingId, date])
  @@index([listingId])
  @@map("availability")
}

// ── Booking ───────────────────────────────────────────────────────────────────
// Core transaction model bridging Listing and Renter.

model Booking {
  id          String        @id @default(cuid())
  listingId   String
  listing     Listing       @relation(fields: [listingId], references: [id])
  renterId    String
  renter      User          @relation("BookingRenter", fields: [renterId], references: [id])
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  totalPrice  Decimal       @db.Decimal(10, 2)
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payment     Payment?
  disputes    Dispute[]

  @@index([listingId])
  @@index([renterId])
  @@map("bookings")
}

// ── Payment ───────────────────────────────────────────────────────────────────
// Follows Razorpay payment lifecycle for a confirmed booking.

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  amount            Decimal       @db.Decimal(10, 2)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("payments")
}

// ── Review ────────────────────────────────────────────────────────────────────
// Reviews left by renters on a listing after completing a booking.

model Review {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now())

  @@unique([listingId, userId])
  @@index([listingId])
  @@map("reviews")
}

// ── Live Chat (Messaging) ──────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  renterId  String
  renter    User     @relation("RenterConversations", fields: [renterId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User     @relation("OwnerConversations", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Updated whenever a new message is sent

  messages  Message[]

  @@unique([listingId, renterId]) // One conversation per renter per listing
  @@index([renterId])
  @@index([ownerId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

// ── Trust & Safety (Disputes) ────────────────────────────────────────────────

model Dispute {
  id          String        @id @default(cuid())
  bookingId   String
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  initiatorId String
  initiator   User          @relation(fields: [initiatorId], references: [id], onDelete: Cascade)
  reason      String        @db.Text
  status      DisputeStatus @default(OPEN)
  adminNotes  String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([bookingId])
  @@index([initiatorId])
  @@map("disputes")
}
